generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username      String   @unique
  email         String   @unique
  password_hash String
  real_balance  Decimal  @default(0) @db.Decimal(20, 2)
  demo_balance  Decimal  @default(5000) @db.Decimal(20, 2)
  kyc_status    String   @default("NONE") @db.VarChar(20)
  rounds_played Int      @default(0)
  is_admin      Int      @default(0)
  banned        Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Provider / seamless-wallet players belong to an external operator. For these
  // users `real_balance` is only a cached mirror — the operator wallet is authoritative.
  operator_id        String?  @db.Uuid
  external_player_id String?
  operator           Operator? @relation(fields: [operator_id], references: [id])

  bets          Bet[]
  transactions  Transaction[]
  sessions      GameSession[]

  @@unique([operator_id, external_player_id])
}

// An integrated operator (a project/casino) that embeds this game and owns its
// own players + wallet. We never hold their money; we call their seamless API.
model Operator {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @unique
  secret_key   String                              // HMAC secret used to sign wallet callbacks
  callback_url String                              // base URL of the operator's seamless wallet API
  currencies   String   @default("USD") @db.VarChar(120) // comma-separated allowed currency codes
  active       Int      @default(1)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  players      User[]
  sessions     GameSession[]
}

// A launched play session for an operator player (created at /provider/launch).
model GameSession {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operator_id  String   @db.Uuid
  user_id      String   @db.Uuid
  currency     String   @db.VarChar(10)
  launch_token String                              // original short-lived token from the operator
  active       Int      @default(1)
  created_at   DateTime @default(now())

  operator     Operator @relation(fields: [operator_id], references: [id])
  user         User     @relation(fields: [user_id], references: [id])
}

model Round {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  crash_point      Decimal   @db.Decimal(10, 2)
  server_seed      String
  server_seed_hash String
  client_seed      String
  nonce            String
  started_at       DateTime  @default(now())
  crashed_at       DateTime?
  
  bets             Bet[]
}

model Bet {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  round_id           String   @db.Uuid
  user_id            String   @db.Uuid
  slot               String   @db.VarChar(10) // e.g., "A" or "B" for dual-bet
  amount             Decimal  @db.Decimal(20, 2)
  currency           String   @db.VarChar(10) // "REAL" or "DEMO"
  auto_cashout       Decimal? @db.Decimal(10, 2)
  multiplier         Decimal? @db.Decimal(10, 2)
  cashout_amount     Decimal? @db.Decimal(20, 2)
  timestamp          DateTime @default(now())
  
  round              Round    @relation(fields: [round_id], references: [id])
  user               User     @relation(fields: [user_id], references: [id])

  @@unique([round_id, user_id, slot]) // Prevent duplicates per slot
}

model Transaction {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  type       String   @db.VarChar(20) // "DEPOSIT" | "WITHDRAWAL"
  amount     Decimal  @db.Decimal(20, 2)
  status     String   @default("SUCCESS") @db.VarChar(20) // "SUCCESS" | "PENDING" | "REJECTED"
  method     String   @db.VarChar(50)
  timestamp  DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id])
}
