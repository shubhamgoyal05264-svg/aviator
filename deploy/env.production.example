# Copy to .env.production on VPS and edit values:
#   cp deploy/env.production.example .env.production

# Database (change password!)
POSTGRES_USER=crash_user
POSTGRES_PASSWORD=change_this_strong_password_123

# Server secrets (generate: openssl rand -hex 32)
JWT_SECRET=change_this_jwt_secret_use_openssl_rand_hex_32

# Admin login (created on first deploy)
ADMIN_EMAIL=admin@skyhigh.com
ADMIN_PASSWORD=Admin123!

# Optional: leave empty for same-origin (recommended for IP deploy)
# Set only if API is on a different domain, e.g. https://api.yourdomain.com
VITE_API_URL=
VITE_SOCKET_URL=

# Host ports
HTTP_PORT=80
ADMIN_PORT=8080
