# baajihub.com production — copy to .env.production on VPS
# cp deploy/env.baajihub.example .env.production

POSTGRES_USER=crash_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

ADMIN_EMAIL=admin@skyhigh.com
ADMIN_PASSWORD=CHANGE_ME_admin_password

# Public URLs (HTTPS after SSL in aaPanel)
VITE_API_URL=https://baajihub.com
VITE_SOCKET_URL=https://baajihub.com

# aaPanel already uses port 80 — Docker uses internal ports, aaPanel proxies to these
HTTP_PORT=3080
ADMIN_PORT=3082
